# Copy to .env.local and fill in.
# Frontend-visible keys (Vite exposes anything prefixed VITE_).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key...

# Server-side (used by Python ingest + Vite dev middleware).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
POLYGON_API_KEY=
IB_HOST=127.0.0.1
IB_PORT=4002
IB_CLIENT_ID=7
# HTTPS_PROXY=
# HTTP_PROXY=
